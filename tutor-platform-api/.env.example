# 複製此檔案為 .env 並修改以下設定

# 資料庫連線字串（PostgreSQL）
DATABASE_URL=postgresql://tmrp:tmrp@localhost:5432/tmrp

# JWT 認證（必填；未設或過短將導致啟動失敗）
# 生成密鑰：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_HEX_FROM_secrets.token_hex_32_AT_LEAST_32_CHARS
# Rotation: set JWT_SECRET_KEY_PREVIOUS to the prior secret during a rollout.
# JWT_SECRET_KEY_PREVIOUS_EXPIRES_AT is REQUIRED when PREVIOUS is set — it
# bounds how long the old key stays trusted (max 7 days, the refresh-token
# TTL). Leave both empty once rotation is complete.
# JWT_SECRET_KEY_PREVIOUS=
# JWT_SECRET_KEY_PREVIOUS_EXPIRES_AT=2026-05-01T00:00:00Z
JWT_ALGORITHM=HS256
# 5-minute access-token TTL matches the defence-in-depth model in config.py.
# Do not raise without also reviewing refresh/rotation behaviour.
JWT_EXPIRE_MINUTES=5

# 系統管理員帳號（首次啟動自動建立；兩者皆必填）
# ADMIN_USERNAME: 'admin' is rejected in production. Pick an opaque value even
# in dev so the same habit carries over. Suggested form:
#   python -c "import secrets; print('owner_' + secrets.token_hex(3))"
# ADMIN_PASSWORD: min 12 chars with at least 3 of {lower, upper, digit, symbol}.
ADMIN_USERNAME=owner_change_me
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_12PLUS_MIXED

# Huey 任務佇列
HUEY_DB_PATH=data/huey.db

# 日誌
LOG_FILE=logs/app.log
LOG_LEVEL=INFO

# 日誌格式（json 或 text）
LOG_FORMAT=json

# CORS（前端開發伺服器位址）
# Vite dev server 預設在 5273（見 tutor-platform-web/vite.config.js）
CORS_ORIGINS=http://localhost:5273
