# 複製此檔案為 .env 並修改以下設定

# 資料庫路徑（相對於 tutor-platform-api/）
ACCESS_DB_PATH=data/tutoring.accdb

# JWT 認證（務必改為隨機長字串）
# 生成密鑰：python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️ 使用預設值 "change-me-in-production" 將無法啟動！
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15

# 系統管理員帳號（首次啟動自動建立）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-too

# Huey 任務佇列
HUEY_DB_PATH=data/huey.db

# 日誌
LOG_FILE=logs/app.log
LOG_LEVEL=INFO

# 日誌格式（json 或 text）
LOG_FORMAT=json

# CORS（前端開發伺服器位址）
CORS_ORIGINS=http://localhost:5173
