# Docker 環境設定
# 複製為 .env.docker 並修改密鑰：
#   cp .env.docker.example .env.docker

# DATABASE_URL 由 docker-compose 從 repo 根目錄 .env 動態組裝，請勿在此宣告。
# （若需在容器外手動跑 API，請另設 DATABASE_URL，但勿提交。）

# JWT_SECRET_KEY 必填且至少 32 字元：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_HEX_FROM_secrets.token_hex_32_AT_LEAST_32_CHARS
# 輪換新 JWT_SECRET_KEY 時，把舊值搬到此變數，給未過期的 token 一段過渡期再清空。
# JWT_SECRET_KEY_PREVIOUS=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=5

# ADMIN_PASSWORD 必填且長度 >= 8
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

HUEY_DB_PATH=data/huey.db

LOG_FILE=logs/app.log
LOG_LEVEL=INFO
LOG_FORMAT=json

CORS_ORIGINS=http://localhost,http://localhost:80
