# Docker environment template. Copy to .env.docker (gitignored).
#   cp .env.docker.example .env.docker
#
# Secrets live in files under repo-root ./secrets/ (also gitignored) and are
# injected by docker-entrypoint.sh. Do NOT put these values in this file:
#   - DATABASE_URL       : built from db_password secret + DB_* vars
#   - JWT_SECRET_KEY     : sourced from secrets/jwt_secret_key.txt
#   - JWT_SECRET_KEY_PREVIOUS (optional) : secrets/jwt_secret_key_previous.txt
#   - ADMIN_PASSWORD     : sourced from secrets/admin_password.txt
#
# To bootstrap a new deployment:
#   cp secrets/jwt_secret_key.txt.example secrets/jwt_secret_key.txt
#     && python -c "import secrets; print(secrets.token_hex(32))" > secrets/jwt_secret_key.txt
#   cp secrets/admin_password.txt.example secrets/admin_password.txt
#     && echo "<strong-password>" > secrets/admin_password.txt
#   cp secrets/jwt_secret_key_previous.txt.example secrets/jwt_secret_key_previous.txt  # leave empty

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=5

# INFO-3: pick a non-obvious bootstrap username (config rejects the literal
# 'admin' when DEBUG=false). Suggested form: owner_<random6>, e.g.
#   python -c "import secrets; print('owner_' + secrets.token_hex(3))"
ADMIN_USERNAME=owner_change_me

HUEY_DB_PATH=data/huey.db

LOG_FILE=logs/app.log
LOG_LEVEL=INFO
LOG_FORMAT=json

CORS_ORIGINS=http://localhost,http://localhost:80

# SEC-C02: set to true when serving over HTTPS (auth cookies require Secure flag).
COOKIE_SECURE=true
