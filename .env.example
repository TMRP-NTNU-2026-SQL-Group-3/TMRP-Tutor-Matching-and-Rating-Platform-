# docker-compose 變數插值來源（位於 repo 根目錄）
# 複製為 `.env` 後修改值；本檔由 .gitignore 排除。
#   cp .env.example .env

# PostgreSQL 帳號與資料庫名稱。
# SEC-H04: password is stored separately in secrets/db_password.txt
# (see secrets/db_password.txt.example). Do NOT put the password here.
DB_USER=tmrp
DB_NAME=tmrp

# Fixed IP assigned to the nginx (web) sidecar on the appnet bridge.
# Must match the ipv4_address in docker-compose.yml and the value is
# embedded in FORWARDED_ALLOW_IPS so uvicorn trusts XFF from that hop.
# Change only if this address conflicts with an existing subnet on the host.
WEB_IP=172.28.0.10
